{
  "name": "@bettersync/better-sqlite3-adapter",
  "version": "0.0.1",
  "description": "better-sqlite3 adapter for bettersync (SQLite for Node.js/Electron)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bettersync/core": "workspace:*"
  },
  "peerDependencies": {
    "better-sqlite3": ">=11.0.0"
  },
  "devDependencies": {
    "@bettersync/test-utils": "workspace:*",
    "better-sqlite3": "^11.6.0",
    "@types/better-sqlite3": "^7.6.12",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "publishConfig": { "access": "public" }
}
