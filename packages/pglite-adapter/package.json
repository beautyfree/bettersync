{
  "name": "@better-sync/pglite-adapter",
  "version": "0.0.1",
  "description": "PGlite (Postgres WASM) adapter for better-sync — same SQL dialect as server, runs in browser/Node",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@better-sync/core": "workspace:*"
  },
  "peerDependencies": {
    "@electric-sql/pglite": ">=0.2.0"
  },
  "devDependencies": {
    "@better-sync/test-utils": "workspace:*",
    "@electric-sql/pglite": "^0.2.17",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
